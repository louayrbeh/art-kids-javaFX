<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.artkids.controller.auth.HomeController"
            prefWidth="1280.0" prefHeight="820.0" styleClass="page home-page">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16.0" styleClass="home-topbar">
            <padding>
                <Insets top="16.0" right="32.0" bottom="16.0" left="32.0"/>
            </padding>
            <Label text="ArtKids" styleClass="home-brand"/>
            <Label text="Gestion artistique pour enfants" styleClass="muted-text"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Se connecter" onAction="#showLogin" styleClass="secondary-button"/>
            <Button text="Creer un compte parent" onAction="#showRegister" styleClass="primary-button"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="page-scroll">
            <content>
                <VBox spacing="28.0" styleClass="page-content">
                    <padding>
                        <Insets top="32.0" right="42.0" bottom="42.0" left="42.0"/>
                    </padding>

                    <HBox spacing="28.0" styleClass="home-hero">
                        <padding>
                            <Insets top="34.0" right="34.0" bottom="34.0" left="34.0"/>
                        </padding>
                        <VBox spacing="18.0" HBox.hgrow="ALWAYS">
                            <Label text="Une plateforme claire pour piloter les activites artistiques." wrapText="true"
                                   styleClass="home-hero-title"/>
                            <Label text="ArtKids reunit l'espace parent, les reservations et le back-office administrateur dans une interface desktop moderne, rapide et lisible."
                                   wrapText="true" styleClass="home-hero-text"/>
                            <HBox spacing="12.0">
                                <Button text="Se connecter" onAction="#showLogin" styleClass="primary-button"/>
                                <Button text="Creer un compte parent" onAction="#showRegister" styleClass="secondary-button"/>
                            </HBox>
                        </VBox>
                        <VBox spacing="16.0" prefWidth="360.0" styleClass="home-visual">
                            <Label text="Aujourd'hui" styleClass="card-title"/>
                            <Label text="6 activites mockees" styleClass="section-title"/>
                            <Label text="Reservations, enfants et catalogue restent en memoire pour cette version JavaFX."
                                   wrapText="true"/>
                            <HBox spacing="12.0">
                                <VBox spacing="4.0" styleClass="hero-card" HBox.hgrow="ALWAYS">
                                    <Label text="Parent" styleClass="card-title"/>
                                    <Label text="Front-office" styleClass="section-title"/>
                                </VBox>
                                <VBox spacing="4.0" styleClass="hero-card" HBox.hgrow="ALWAYS">
                                    <Label text="Admin" styleClass="card-title"/>
                                    <Label text="Back-office" styleClass="section-title"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <FlowPane hgap="16.0" vgap="16.0" prefWrapLength="1100.0">
                        <VBox spacing="8.0" prefWidth="260.0" styleClass="feature-card">
                            <Label text="Espace Parent" styleClass="section-title"/>
                            <Label text="Enfants, activites disponibles, reservations et annulations depuis une navigation simple."
                                   wrapText="true" styleClass="card-text"/>
                        </VBox>
                        <VBox spacing="8.0" prefWidth="260.0" styleClass="feature-card">
                            <Label text="Back-Office Admin" styleClass="section-title"/>
                            <Label text="Gestion des categories, activites, utilisateurs, enfants et reservations mockees."
                                   wrapText="true" styleClass="card-text"/>
                        </VBox>
                        <VBox spacing="8.0" prefWidth="260.0" styleClass="feature-card">
                            <Label text="Catalogue artistique" styleClass="section-title"/>
                            <Label text="Dessin, peinture, musique, theatre, danse et sculpture avec suivi des places."
                                   wrapText="true" styleClass="card-text"/>
                        </VBox>
                        <VBox spacing="8.0" prefWidth="260.0" styleClass="feature-card">
                            <Label text="Session mockee" styleClass="section-title"/>
                            <Label text="Aucune integration MySQL ou Symfony: les donnees restent en memoire."
                                   wrapText="true" styleClass="card-text"/>
                        </VBox>
                    </FlowPane>

                    <HBox spacing="16.0">
                        <VBox spacing="6.0" styleClass="metric-card" HBox.hgrow="ALWAYS">
                            <Label text="Comptes demo" styleClass="card-title"/>
                            <Label text="2" styleClass="stat-value"/>
                            <Label text="Admin et parent preconfigures" styleClass="card-text"/>
                        </VBox>
                        <VBox spacing="6.0" styleClass="metric-card" HBox.hgrow="ALWAYS">
                            <Label text="Activites" styleClass="card-title"/>
                            <Label text="6" styleClass="stat-value"/>
                            <Label text="Catalogue de demonstration" styleClass="card-text"/>
                        </VBox>
                        <VBox spacing="6.0" styleClass="metric-card" HBox.hgrow="ALWAYS">
                            <Label text="Reservations" styleClass="card-title"/>
                            <Label text="4" styleClass="stat-value"/>
                            <Label text="Workflow parent et admin" styleClass="card-text"/>
                        </VBox>
                    </HBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
