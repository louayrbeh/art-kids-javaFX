<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.artkids.controller.backoffice.AdminCategoryFormController"
            prefWidth="1360.0" prefHeight="860.0" styleClass="page admin-page">
    <left>
        <VBox spacing="12.0" prefWidth="260.0" styleClass="sidebar">
            <padding>
                <Insets top="24.0" right="18.0" bottom="24.0" left="18.0"/>
            </padding>
            <Label text="ArtKids Admin" styleClass="sidebar-title"/>
            <Button text="Dashboard" onAction="#cancel" maxWidth="Infinity" styleClass="sidebar-button"/>
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>
    <center>
        <VBox alignment="TOP_CENTER" styleClass="page-content">
            <padding>
                <Insets top="32.0" right="32.0" bottom="32.0" left="32.0"/>
            </padding>
            <VBox spacing="18.0" maxWidth="760.0" styleClass="form-card">
                <Label fx:id="pageTitleLabel" text="Ajouter une categorie" styleClass="page-title"/>
                <GridPane hgap="16.0" vgap="14.0">
                    <Label text="Nom" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="nomField" promptText="Nom de la categorie" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label text="Description" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextArea fx:id="descriptionArea" prefRowCount="4" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    <Label text="Image" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="imageField" promptText="nom-image.png" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                </GridPane>
                <VBox spacing="12.0">
                    <Button text="Enregistrer" onAction="#saveCategory" styleClass="primary-button"/>
                    <Button text="Annuler" onAction="#cancel" styleClass="secondary-button"/>
                </VBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
