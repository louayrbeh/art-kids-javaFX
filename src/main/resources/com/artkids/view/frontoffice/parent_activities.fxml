<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.artkids.controller.frontoffice.ParentActivityController"
            prefWidth="1280.0" prefHeight="820.0" styleClass="page parent-page">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="appbar">
            <padding>
                <Insets top="16.0" right="24.0" bottom="16.0" left="24.0"/>
            </padding>
            <Label text="ArtKids Parent" styleClass="sidebar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Dashboard" onAction="#goToDashboard" styleClass="secondary-button"/>
            <Button text="Mes enfants" onAction="#goToChildren" styleClass="secondary-button"/>
            <Button text="Reservations" onAction="#goToReservations" styleClass="secondary-button"/>
            <Button text="Deconnexion" onAction="#logout" styleClass="danger-button"/>
        </HBox>
    </top>
    <center>
        <VBox spacing="18.0" styleClass="page-content">
            <padding>
                <Insets top="28.0" right="28.0" bottom="28.0" left="28.0"/>
            </padding>
            <VBox spacing="6.0">
                <Label text="Activites disponibles" styleClass="page-title"/>
                <Label text="Filtrez les activites ouvertes selon vos besoins puis consultez leur fiche detail."
                       styleClass="page-subtitle" wrapText="true"/>
            </VBox>

            <HBox spacing="12.0" styleClass="card">
                <TextField fx:id="searchField" promptText="Recherche par titre..." HBox.hgrow="ALWAYS"/>
                <ComboBox fx:id="categoryComboBox" prefWidth="220.0"/>
                <TextField fx:id="ageField" promptText="Age enfant" prefWidth="120.0"/>
                <Button text="Filtrer" onAction="#applyFilters" styleClass="primary-button"/>
                <Button text="Reinitialiser" onAction="#resetFilters" styleClass="secondary-button"/>
            </HBox>

            <TableView fx:id="activitiesTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="titreColumn" text="Titre" prefWidth="190.0"/>
                    <TableColumn fx:id="categoryColumn" text="Categorie" prefWidth="150.0"/>
                    <TableColumn fx:id="dateColumn" text="Date" prefWidth="120.0"/>
                    <TableColumn fx:id="timeColumn" text="Horaire" prefWidth="160.0"/>
                    <TableColumn fx:id="ageRangeColumn" text="Tranche d'age" prefWidth="130.0"/>
                    <TableColumn fx:id="placesColumn" text="Places" prefWidth="90.0"/>
                    <TableColumn fx:id="statutColumn" text="Statut" prefWidth="120.0"/>
                    <TableColumn fx:id="actionColumn" text="Action" prefWidth="120.0"/>
                </columns>
            </TableView>
        </VBox>
    </center>
</BorderPane>
