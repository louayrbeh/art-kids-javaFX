<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.artkids.controller.frontoffice.ParentChildFormController"
            prefWidth="1280.0" prefHeight="820.0" styleClass="page parent-page">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="appbar">
            <padding>
                <Insets top="16.0" right="24.0" bottom="16.0" left="24.0"/>
            </padding>
            <Label text="ArtKids Parent" styleClass="sidebar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Retour a la liste" onAction="#cancel" styleClass="secondary-button"/>
        </HBox>
    </top>
    <center>
        <VBox alignment="TOP_CENTER" styleClass="page-content">
            <padding>
                <Insets top="32.0" right="32.0" bottom="32.0" left="32.0"/>
            </padding>
            <VBox spacing="18.0" maxWidth="760.0" styleClass="form-card">
                <Label fx:id="pageTitleLabel" text="Ajouter un enfant" styleClass="page-title"/>
                <GridPane hgap="16.0" vgap="14.0">
                    <Label text="Nom" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="nomField" promptText="Nom de famille" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label text="Prenom" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="prenomField" promptText="Prenom" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                    <Label text="Date de naissance" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <DatePicker fx:id="birthDatePicker" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                    <Label text="Sexe" styleClass="form-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="sexeComboBox" prefWidth="220.0" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                </GridPane>
                <HBox spacing="12.0">
                    <Button text="Enregistrer" onAction="#saveChild" styleClass="primary-button"/>
                    <Button text="Annuler" onAction="#cancel" styleClass="secondary-button"/>
                </HBox>
            </VBox>
        </VBox>
    </center>
</BorderPane>
