<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.artkids.controller.frontoffice.ParentActivityDetailsController"
            prefWidth="1280.0" prefHeight="820.0" styleClass="page parent-page">
    <top>
        <HBox alignment="CENTER_LEFT" spacing="12.0" styleClass="appbar">
            <padding>
                <Insets top="16.0" right="24.0" bottom="16.0" left="24.0"/>
            </padding>
            <Label text="ArtKids Parent" styleClass="sidebar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Retour aux activites" onAction="#backToActivities" styleClass="secondary-button"/>
        </HBox>
    </top>
    <center>
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER">
            <content>
                <VBox alignment="TOP_CENTER" styleClass="page-content">
                    <padding>
                        <Insets top="32.0" right="32.0" bottom="32.0" left="32.0"/>
                    </padding>
                    <VBox spacing="18.0" maxWidth="920.0" styleClass="card">
                        <Label fx:id="titleLabel" text="Titre activite" styleClass="page-title"/>
                        <Label fx:id="descriptionLabel" wrapText="true"/>
                        <GridPane hgap="16.0" vgap="14.0">
                            <Label text="Categorie" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                            <Label fx:id="categoryLabel" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                            <Label text="Date" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                            <Label fx:id="dateLabel" GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                            <Label text="Horaire" styleClass="form-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                            <Label fx:id="timeLabel" GridPane.rowIndex="2" GridPane.columnIndex="1"/>
                            <Label text="Lieu" styleClass="form-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                            <Label fx:id="locationLabel" GridPane.rowIndex="3" GridPane.columnIndex="1"/>
                            <Label text="Prix" styleClass="form-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                            <Label fx:id="priceLabel" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
                            <Label text="Places disponibles" styleClass="form-label" GridPane.rowIndex="5" GridPane.columnIndex="0"/>
                            <Label fx:id="placeLabel" GridPane.rowIndex="5" GridPane.columnIndex="1"/>
                            <Label text="Ages autorises" styleClass="form-label" GridPane.rowIndex="6" GridPane.columnIndex="0"/>
                            <Label fx:id="ageLabel" GridPane.rowIndex="6" GridPane.columnIndex="1"/>
                            <Label text="Statut" styleClass="form-label" GridPane.rowIndex="7" GridPane.columnIndex="0"/>
                            <Label fx:id="statusLabel" GridPane.rowIndex="7" GridPane.columnIndex="1"/>
                        </GridPane>

                        <VBox spacing="10.0" styleClass="form-card">
                            <Label text="Reserver pour un enfant" styleClass="section-title"/>
                            <ComboBox fx:id="childComboBox" promptText="Selectionnez un enfant"/>
                            <Button text="Reserver" onAction="#reserveActivity" styleClass="primary-button"/>
                        </VBox>

                        <VBox spacing="10.0" styleClass="form-card">
                            <Label text="Compatibilite de vos enfants" styleClass="section-title"/>
                            <ListView fx:id="compatibilityList" prefHeight="180.0"/>
                        </VBox>
                    </VBox>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
